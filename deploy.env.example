# Product MCP deployment environment
#
# Use one deployment per backend environment.
# Staging MCP should point to staging API; production MCP should point to production API.

PRODUCT_MCP_PORT=8787
PRODUCT_MCP_HOST=0.0.0.0
PRODUCT_MCP_PATH=/mcp

# Optional. Set after the server domain is stable.
# Example: PRODUCT_MCP_ALLOWED_HOSTS=mcp.company.com,10.0.0.12
PRODUCT_MCP_ALLOWED_HOSTS=

# Must be the server-side gateway/base URL that exposes the same API as frontend VITE_APP_BASE_API.
# Example: https://erp.company.com/api
PRODUCT_MCP_BACKEND_BASE_URL=

PRODUCT_MCP_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e
PRODUCT_MCP_REQUEST_TIMEOUT_MS=50000
PRODUCT_MCP_DEFAULT_LANGUAGE=zh_CN
